# Prosper Backend Environment Configuration
# Copy this file to .env and fill in your values

# ── Django ───────────────────────────────────────
SECRET_KEY=your-secret-key-change-this-in-production-use-openssl-rand-64
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,yourdomain.com

# ── Database (Supabase PostgreSQL) ─────────────────
# Get connection string from Supabase Dashboard:
# Settings → Database → Connection string → "URI" format
# Example:
# DATABASE_URL=postgres://postgres.[PROJECT_REF]:[YOUR_PASSWORD]@aws-0-africa-south-1.pooler.supabase.com:5432/postgres
DATABASE_URL=

# ── JWT Authentication ────────────────────────────
# Optional: If not set, uses SECRET_KEY
# JWT_SECRET_KEY=your-jwt-secret-key

# ── CORS (Cross-Origin Resource Sharing) ──────────
# Development: CORS_ALLOW_ALL_ORIGINS=True (in .env override)
# Production: List exact origins (Expo, your app domain)
# CORS_ALLOWED_ORIGINS=https://prosper.app,exp://localhost:19000

# ── Email (Optional) ──────────────────────────────
# Default: Console backend (prints to stdout)
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# For production SMTP:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password

# ── Frontend URLs (Optional) ───────────────────────
# FRONTEND_URL=http://localhost:8081
# FRONTEND_URL=https://prosper.app

# ── Rate Limiting (Optional) ───────────────────────
# REST_FRAMEWORK_RATE_LIMIT=100/hour
